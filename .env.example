# ──────────────────────────────────────────────────────────────
# AgroWeather WhatsApp Bot — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control!
# ──────────────────────────────────────────────────────────────

# ── Node environment ──────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Twilio (Required) ─────────────────────────────────────────
# Get these from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# ── Google Gemini AI (Required) ───────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OpenWeatherMap (Optional but recommended) ─────────────────
# Free tier: 1,000 calls/day — https://openweathermap.org/api
# If not set, Gemini uses its training knowledge for weather (less precise)
OPENWEATHER_API_KEY=your_owm_api_key_here

# ── Security (Production) ─────────────────────────────────────
# Your public URL (used for Twilio signature validation in production)
# BASE_URL=https://yourdomain.com
